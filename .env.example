# Base de datos (Railway Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/chatbot

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta (WhatsApp + Instagram)
META_ACCESS_TOKEN=EAAxxxxxxx
META_VERIFY_TOKEN=              # token que vos elegís; lo cargás igual en el panel de webhooks de Meta (fail-closed: sin esto el handshake devuelve 503)
META_APP_SECRET=                 # App Secret de Meta -> valida la firma del webhook (fail-closed: si falta, el webhook se rechaza con 403)
# ALLOW_UNSIGNED_WEBHOOKS=1      # solo dev (NO en prod): acepta webhooks sin firma si falta META_APP_SECRET
META_WHATSAPP_PHONE_ID=123456789
META_INSTAGRAM_ACCOUNT_ID=123456789

# WhatsApp: ventana de servicio de 24h. Pasadas 24h del último mensaje del usuario,
# Graph rechaza el free-form (type:text) y hay que mandar una PLANTILLA aprobada.
# La plantilla se crea y aprueba en Meta (WhatsApp Manager) -> es tarea tuya, fuera
# del código. Una vez aprobada, poné acá su NOMBRE EXACTO. Vacío = no se reabre la
# conversación fuera de ventana (se loguea y se omite el envío).
WHATSAPP_REENGAGE_TEMPLATE=          # ej: reengage_lead_v1
# WHATSAPP_REENGAGE_TEMPLATE_LANG=es_AR   # código de idioma de la plantilla (default es_AR)

# Re-engagement PROACTIVO de leads fuera de la ventana de 24h (servicio reengage_service +
# endpoint POST /reengage/run). APAGADO por default y con doble gate: hasta que prendas el
# flag Y cargues una plantilla aprobada, el servicio es un NO-OP (no manda nada).
REENGAGE_ENABLED=0                   # 1 = habilita el re-engagement proactivo (default 0 = apagado)
REENGAGE_TEMPLATE_NAME=              # nombre EXACTO de la plantilla aprobada en Meta. Vacío =
                                     # cae a WHATSAPP_REENGAGE_TEMPLATE; si ambas vacías, no manda nada.
# Palabras de baja: si un inbound de WhatsApp matchea (exacto, trim + case-insensitive) alguna,
# se marca opt-out y el re-engagement deja de escribirle a ese lead. Coma-separadas.
REENGAGE_OPTOUT_KEYWORDS=BAJA,STOP,CANCELAR

# Auth de endpoints internos (/leads, /ads). Sin esto quedan cerrados (fail-closed).
ADMIN_API_KEY=                   # un token secreto fuerte, lo mandás como "Authorization: Bearer <token>"

# CORS: dominios donde se EMBEBE el widget, separados por comas. Si lo dejás vacío,
# usa el default (los sitios propios de los 3 proyectos). En dev (CHATBOT_DEV=1) se
# abre solo. Poné "*" SOLO si querés abrirlo a cualquier sitio en prod (no recomendado).
# ALLOWED_ORIGINS=https://gonzaloferraroautomoviles.ar,https://mesa-production-d6a9.up.railway.app

# Ruteo opcional por número/formulario (JSON). Si vacío, todo cae en "agencia".
# WHATSAPP_NUMBER_TO_PROJECT={"541165613300":"mesa"}
# LEAD_FORM_TO_PROJECT={"123456789":"agencia"}

# Observabilidad: nivel de logging (DEBUG, INFO, WARNING, ERROR). Default INFO.
# LOG_LEVEL=INFO
